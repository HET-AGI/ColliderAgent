# Collider Agent Environment Variables
# Copy this file to .env and update with your actual values

# ============================================================================
# LLM Configuration
# ============================================================================
# Options: gpt-4, gpt-4o, openai/gpt-5-mini, gemini-3-pro-preview, etc.
COLLIDER_AGENT_MODEL=openai/gpt-5-mini
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Maximum agent conversation turns (max LLM calls). Overridable by --max-turns.
# COLLIDER_AGENT_MAX_TURNS=20

# ============================================================================
# MadGraph5 Configuration
# ============================================================================
# Path to mg5_aMC executable (typically .../MG5_aMC_v3_6_6/bin)
# If set, Delphes paths below are derived automatically from MG5_PATH
MG5_PATH=/path/to/MG5_aMC_v3_6_6/bin

# Optional: Override Delphes paths (defaults are derived from MG5_PATH)
# DELPHES_PATH=/path/to/MG5_aMC_v3_6_6/Delphes
# DELPHES_CARD_CMS=/path/to/MG5_aMC_v3_6_6/Delphes/cards/delphes_card_CMS.tcl
# DELPHES_CARD_ATLAS=/path/to/MG5_aMC_v3_6_6/Delphes/cards/delphes_card_ATLAS.tcl

# ============================================================================
# MadAnalysis5 Configuration
# ============================================================================
# Path to ma5 executable directory (typically .../madanalysis5/bin)
MA5_PATH=/path/to/madanalysis5/bin

# ============================================================================
# Simulation Defaults
# ============================================================================
# Default number of events to generate
DEFAULT_NEVENTS=10000

# Default beam energies (GeV)
DEFAULT_EBEAM1=6500
DEFAULT_EBEAM2=6500

# ============================================================================
# Magnus Cloud Configuration
# ============================================================================
# Used by mcp_mma tool for Mathematica code execution
MAGNUS_ADDRESS=http://162.105.131.134:3011
MAGNUS_TOKEN=sk-your-magnus-token-here
# Result storage path for FeynRules validation (JSON output)
MAGNUS_RESULT=/data/magnus/results.json
