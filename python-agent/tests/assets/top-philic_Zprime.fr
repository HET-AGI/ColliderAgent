LZp:= (
       +(2/3)*g3*{tbar[sp1],tPbar[sp1]}.{{sL^2, -sL*cL}, {-sL*cL,cL^2}}.{Ga[mu, sp1, sp2].ProjM[sp2,sp3].t[sp3], Ga[mu, sp1, sp2].ProjM[sp2,sp3].tP[sp3]}*Zp[mu]
       +(2/3)*g3*{tbar[sp1],tPbar[sp1]}.{{sR^2, -sR*cR}, {-sR*cR,cR^2}}.{Ga[mu, sp1, sp2].ProjP[sp2,sp3].t[sp3], Ga[mu, sp1, sp2].ProjP[sp2,sp3].tP[sp3]}*Zp[mu]
